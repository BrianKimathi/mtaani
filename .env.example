# ── Server ──
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
PORT=4000
FRONTEND_URL="http://localhost:5173"
CORS_ORIGINS="http://localhost:5173,https://bekye-swap.web.app"

# ── Firebase project: kile-kitabu ──
FIREBASE_PROJECT_ID="kile-kitabu"
FIREBASE_DATABASE_URL="https://kile-kitabu-default-rtdb.firebaseio.com"
FIREBASE_STORAGE_BUCKET="kile-kitabu.appspot.com"

# Isolated paths (do not change unless you know what you're doing)
FIREBASE_RTD_ROOT="bekye_swap"
FIREBASE_STORAGE_ROOT="bekye_swap"

# Service account at repo root (download from Firebase Console → Service accounts)
FIREBASE_SERVICE_ACCOUNT_PATH="../service.json"

UPLOAD_DIR="./uploads"

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM="Bekye Swap <your.email@gmail.com>"
DEV_LOG_OTP=false
