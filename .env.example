# ── Server ──
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
PORT=4000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# ── Firebase project ──
FIREBASE_PROJECT_ID=kile-kitabu
FIREBASE_DATABASE_URL=https://kile-kitabu-default-rtdb.firebaseio.com
FIREBASE_STORAGE_BUCKET=kile-kitabu.appspot.com
FIREBASE_RTD_ROOT=bekye_swap
FIREBASE_STORAGE_ROOT=bekye_swap

# ── Service account (one env var per service.json field) — copy to Vercel ──
# Run locally: npm run env:sync-sa  (reads ../service.json → fills .env)
FIREBASE_SA_TYPE=service_account
FIREBASE_SA_PROJECT_ID=kile-kitabu
FIREBASE_SA_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_SA_CLIENT_EMAIL=firebase-adminsdk-xxxxx@kile-kitabu.iam.gserviceaccount.com
FIREBASE_SA_CLIENT_ID=your-client-id
FIREBASE_SA_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_SA_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_SA_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_SA_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/...
FIREBASE_SA_UNIVERSE_DOMAIN=googleapis.com

UPLOAD_DIR=./uploads
DEV_LOG_OTP=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=Bekye Swap <your.email@gmail.com>
