# ── Server ──
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
PORT=4000
FRONTEND_URL="http://localhost:5173"
CORS_ORIGINS="http://localhost:5173,https://your-frontend.vercel.app"

# ── Firebase (kile-kitabu) ──
FIREBASE_PROJECT_ID="kile-kitabu"
FIREBASE_DATABASE_URL="https://kile-kitabu-default-rtdb.firebaseio.com"
FIREBASE_STORAGE_BUCKET="kile-kitabu.appspot.com"
FIREBASE_RTD_ROOT="bekye_swap"
FIREBASE_STORAGE_ROOT="bekye_swap"

# Credentials — pick ONE method:
#
# A) Local dev: point to service.json file (repo root)
FIREBASE_SERVICE_ACCOUNT_PATH="../service.json"
#
# B) Vercel / production: paste entire service.json as ONE line (no file upload on Vercel)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"kile-kitabu",...}

UPLOAD_DIR="./uploads"

# ── Gmail OTP ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="Bekye Swap <your.email@gmail.com>"
DEV_LOG_OTP=false
